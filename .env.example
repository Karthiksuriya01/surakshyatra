# Copy this file to .env and fill in your values.
# Get Gemini keys from: https://aistudio.google.com/app/apikey
# Get Maps key from: https://console.cloud.google.com/

# ── Google Maps ───────────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# ── Gemini API Keys (one per concern — each has its own 60 req/min quota) ─────
# AI 1: Trip preferences generation
VITE_GEMINI_KEY_PREFERENCES=your_gemini_key_1_here

# AI 2: Itinerary generation
VITE_GEMINI_KEY_ITINERARY=your_gemini_key_2_here

# AI 3: Safety ML parameters + explanation
VITE_GEMINI_KEY_SAFETY=your_gemini_key_3_here

# AI 4: Place insights + chat assistant
VITE_GEMINI_KEY_PLACES=your_gemini_key_4_here

# ── FastAPI ML server ──────────────────────────────────────────────────────────
VITE_ML_API_URL=http://localhost:8000
